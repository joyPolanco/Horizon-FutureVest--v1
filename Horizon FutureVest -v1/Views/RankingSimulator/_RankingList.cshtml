<div class="container-fluid mt-2 h-100 overflow-y-scroll" style="max-height:500px">

    @if (Model.Count < 2)
    {
        @if (Model.Count == 0)
        {
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light border-bottom position-sticky top-0" style="z-index: 1;">
                    <tr class="fw-semibold text-secondary">
                        <th class="text-center">#</th>
                        <th>Nombre País</th>
                        <th>Código ISO</th>
                        <th class="text-center">Score</th>
                        <th class="text-center">Tasa estimada de retorno</th>
                    </tr>
                </thead>
                </table>
        }
        else
        {
            <div class="alert alert-warning">
                <p>
                    “No hay suficientes países para calcular el ranking y la tasa de retorno.
                    El único país que cumple con los requisitos es <strong>@Model.First().CountryName</strong>.
                    Debe agregar más indicadores a los demás países en el año seleccionado.”
                </p>
                <a href="Indicators" class="btn btn-sm btn-outline-primary">Ir al mantenimiento de indicadores por países</a>
            </div>
        }
    }
    else
    {
        <div class="table-responsive shadow-sm rounded border bg-white" style="max-height: 500px; overflow-y: auto;">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light border-bottom position-sticky top-0" style="z-index: 1;">
                    <tr class="fw-semibold text-secondary">
                        <th class="text-center">#</th>
                        <th>Nombre País</th>
                        <th>Código ISO</th>
                        <th class="text-center">Score</th>
                        <th class="text-center">Tasa estimada de retorno</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <tr>
                            <td class="text-center fw-bold">@((i + 1))</td>
                            <td>@Model[i].CountryName</td>
                            <td>@Model[i].CountryIsoCode</td>
                            <td class="text-center">@Model[i].Score</td>
                            <td class="text-center">@Model[i].ReturnInvestmentRate</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
