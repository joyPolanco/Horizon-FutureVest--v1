@using Application.ViewModels.RankingSimulation
@model SimulatorPageFilterViewModel

@{
    ViewData["Title"] = "Simulador de ranking";
}

<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="fs-7 text-light">Listado de macroindicadores</h2>
            <a asp-action="Add" asp-controller="SimulationMacroindicators" class="btn btn-primary mb-2">
                + Agregar macroindicador
            </a>
        </div>
    </div>

    @if (Model.Macroindicators.Count == 0)
    {

        <p class="lead fst-italic text-center text-muted">
            No hay macroindicadores registrados en la simulación
        </p>
    }
    else
    {
        <div class="row g-3 p-2 bg-white rounded shadow-sm bg-secondary-subtle" style="max-height: 500px; overflow-y: auto;">
            @foreach (var item in Model.Macroindicators)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3" style="max-width:190px">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column justify-content-between rounded shadow">
                            <div>
                                <h5 class="card-title text-secondary mb-2">
                                    Nombre: <strong>@item.Name</strong>
                                </h5>
                                <p class="mb-1">
                                    <span class="badge bg-primary">Peso: @item.WeightFactor / 1</span>
                                </p>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-2">
                                <a class="btn btn-sm btn-warning" asp-controller="SimulationMacroindicators" asp-action="Edit" asp-route-id="@item.Id">
                                    Editar
                                </a>
                                <a class="btn btn-sm btn-danger" asp-controller="SimulationMacroindicators" asp-action="Delete" asp-route-id="@item.Id">
                                    Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

    }


    <div class="mt-4  bg-light rounded shadow-sm h-25">
        <form asp-controller="RankingSimulator" method="post" asp-action="Filter" class="p-3 rounded shadow-sm bg-white border">
            <div class="row align-items-end g-3">
                <div class="col-auto">
                    <label class="form-label text-secondary">Año</label>
                    <select class="form-select shadow-sm"
                            asp-for="SelectedYear"
                            asp-items="new SelectList(Model.IndicatorsYear, Model.IndicatorsYear.Any() ? Model.IndicatorsYear.Max() : (int?)null)">
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary px-4 shadow-sm" type="submit">Filtrar</button>
                </div>
            </div>
        </form>
    </div>

    @if (ViewBag.SumMacroIsValid != null)
    {
        <div class="alert alert-warning shadow-sm mb-2">
            Se deben ajustar los pesos de los macroindicadores agregados a la simulación hasta que la suma sea igual a 1.
        </div>
    }
    else if (ViewBag.NoCountriesMessage != null)
    {
        <div class="alert alert-warning shadow-sm">
            @ViewBag.NoCountriesMessage
        </div>
    }
    else
    {
        <div id="Countries" class="table-responsive shadow-sm rounded border bg-white p-2">
            @await Html.PartialAsync("_RankingList", Model.CountryList)
        </div>
    }
</div>
