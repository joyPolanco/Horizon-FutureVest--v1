@using Application.ViewModels.MacroeconomicIndicator
@model List<MacroeconomicIndicatorViewModel>
@{
    ViewData["Title"] = "Macroindicadores";
}

<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-end">
            <a asp-action="Add" asp-controller="MacroIndicators" class="btn btn-primary">
                + Agregar macroindicador
            </a>
        </div>
    </div>

    <div class="row mb-3">
        <h2 class="text-light fw-bold text-start border-bottom border-2 pb-2">
            Listado de Macroindicadores
        </h2>
    </div>

    @if (Model.Count == 0)
    {
        <div class="row g-3 p-2 bg-secondary-subtle rounded shadow-sm" style="max-height: 900px; overflow-y: auto;">

        <p class="lead fst-italic text-center text-muted">No hay macroindicadores registrados</p>
        </div>
    }
    else
    {
        <div class="row g-3 p-2 bg-secondary-subtle rounded shadow-sm" style="max-height: 900px; overflow-y: auto;">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title text-dark mb-2">
                                    Nombre: <strong>@item.Name</strong>
                                </h5>
                                <p class="mb-1">
                                    <span class="badge bg-primary">Peso: @item.WeightFactor / 1</span>
                                </p>
                                <p class="mb-2">
                                    <span class="badge @(item.HigherIsBetter ? "bg-success" : "bg-secondary")">
                                        Tipo: @(item.HigherIsBetter ? "Más alto es mejor" : "Más bajo es mejor")
                                    </span>
                                </p>
                            </div>

                            <div class="d-flex justify-content-end gap-2">
                                <a class="btn btn-sm btn-warning" asp-controller="MacroIndicators" asp-action="Edit" asp-route-id="@item.Id">
                                    Editar
                                </a>
                                <a class="btn btn-sm btn-danger" asp-controller="MacroIndicators" asp-action="Delete" asp-route-id="@item.Id">
                                    Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
