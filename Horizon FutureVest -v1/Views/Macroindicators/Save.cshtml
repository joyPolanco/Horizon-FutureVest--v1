@model SaveMacroindicatorViewModel
@{
    bool isEditMode = ViewBag.IsEditMode ?? false;
    bool? wasSuccesful = ViewBag.WasSuccesful != null ? Convert.ToBoolean(ViewBag.WasSuccesful) : (bool?)null;

}
@if (ViewBag.Message != null)
{
   
    string tipo = wasSuccesful == true ? "success" : "danger";
    

    <div class="alert alert-@tipo alert-dismissible fade show" role="alert">
        <h3 class="lead">@ViewBag.Message </h3>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    @if (wasSuccesful==true)
    {
        <script>
            setTimeout(() => {
                window.location.href = '@Url.Action("Index", "Macroindicators")';
            }, 2000);
        </script>
    }
 


}
<div class="col-12 col-md-6 offset-md-3">
    <div class="card">
        <div class="card-header @(isEditMode ? "bg-warning" : "bg-info") text-light">
            <h5>@(isEditMode ? $"Editar - Macroindicador- ({Model.Name})" : "Agregar macroindicador")  </h5>
        </div>
        <div class="card-body">

            <form asp-controller="MacroIndicators" asp-action="@(isEditMode? "Edit" :"Add")" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"> Nombre: </label>
                    <input class="form-control" asp-for="Name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="WeightFactor" class="form-label"> Peso: </label>
                    <input class="form-control" asp-for="WeightFactor" step="any" min="0" max="1" />
                    <span asp-validation-for="WeightFactor" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="HigherIsBetter" class="form-label"> Tipo de macroindicador: </label>
                    <label class="form-label">¿El indicador es mejor si es más alto?</label>

                    <div class="form-check">
                        <input type="radio" asp-for="HigherIsBetter" value="true" class="form-check-input" />
                        <label class="form-check-label">Sí</label>
                    </div>
                    <div class="form-check">
                        <input type="radio" asp-for="HigherIsBetter" value="false" class="form-check-input" />
                        <label class="form-check-label">No</label>
                    </div>

                </div>

                <div>
                    <button type="submit" class="btn btn-outline-primary float-end">@(isEditMode ? "Guardar cambios" : "Agregar macroindicador")</button>
                    <a asp-controller="Macroindicators" asp-action="Index" class="btn btn-outline-success">Volver al listado</a>
                </div>
            </form>
        </div>
    </div>
</div>
