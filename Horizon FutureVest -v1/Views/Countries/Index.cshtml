@model List<CountryViewModel>

@{
    ViewData["Title"] = "Mantenimiento de Países";
}

<div class="text-center">

    <div class="row d-flex">
        <div class="col-12">
            <a asp-action="Add" asp-controller="Countries"
               class="btn btn-primary float-end mb-3 shadow-sm">+ Agregar País</a>
        </div>
    </div>
    <div class="row mb-3">
        <h2 class="text-light fw-bold text-start border-bottom border-2 pb-2">
            Listado de Países
        </h2>
    </div>


    <div class="container-fluid">
        @if (Model.Count == 0)
{
            <div style="max-height: 400px; overflow-y: auto;"
                class="p-2 border rounded shadow-sm bg-secondary-subtle">

            <p class="lead fst-italic text-muted">No hay países registrados</p>
            </div>
        } 
        else
        {
            <div style="max-height: 400px; overflow-y: auto;"
                 class="p-2 border rounded shadow-sm bg-secondary-subtle">
                @foreach (var item in Model)
                {
                    <div class="card mb-2 shadow-sm border-0">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <strong class="fs-6">@item.Name</strong><br />
                                <small class="text-muted">ISO: @item.IsoCode</small>
                            </div>
                            <div>
                                <a class="btn btn-sm btn-warning me-1"
                                   asp-controller="Countries" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                                <a class="btn btn-sm btn-danger"
                                   asp-controller="Countries" asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
