@using Application.ViewModels.EconomicIndicator
@model List<EconomicIndicatorViewModel>

<div class="container-fluid mt-2">
    @if (Model.Count == 0)
{
        <div style="max-height: 400px; overflow-y: auto;"  class="p-2 bg-white border rounded shadow-sm">
        <p class="lead fst-italic text-muted">No hay indicadores registrados</p>
        </div>
    }   
    else
    {
        <div style="max-height: 400px; overflow-y: auto;"
             class="p-2 bg-white border rounded shadow-sm">
            @foreach (var item in Model)
            {
                <div class="card mb-2 border-0 shadow-sm">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge bg-primary">Macroindicador: @item.MacroeconomicIndicatorName</span>
                            <span class="badge bg-secondary">País: @item.CountryName</span>
                            <span class="badge bg-success">Valor: @item.Value</span>
                            <span class="badge bg-info text-dark">Año: @item.Year</span>
                        </div>
                        <div class="ms-3">
                            <a class="btn btn-sm btn-warning me-1"
                               asp-controller="Indicators" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                            <a class="btn btn-sm btn-danger"
                               asp-controller="Indicators" asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
