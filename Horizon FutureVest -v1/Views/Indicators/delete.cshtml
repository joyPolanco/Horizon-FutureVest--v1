@using Application.ViewModels.EconomicIndicator
@using Application.ViewModels.MacroeconomicIndicator
@model DeleteEconomicIndicatorViewModel
@if (ViewBag.Message != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <h3 class="lead">@ViewBag.Message </h3>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <script>
        setTimeout(() => {
            window.location.href = '@Url.Action("Index", "Indicators")';
        }, 2000);
    </script>


}
<div class="col-12 col-md-6 offset-md-3">
    <div class="card">
        <div class="card-header bg-danger text-light">
            <h5>Eliminar indicador económico</h5>
        </div>
        <div class="card-body">

            <form asp-controller="Indicators" asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                     <h5 class=" d-flex">
                        <span class="badge bg-secondary ms-1"> País :  @Model.CountryName</span>
                        <span class="badge bg-info ms-1"> Macroindicador : @Model.MacroIndicatorName</span>
                        <span class="badge bg-primary ms-1"> Año :  @Model.Year</span>
                        <span class="badge bg-warning ms-1"> Valor : @Model.Value</span>

                     </h5>
                    <h4 class="text-center">
                        ¿Está seguro que desea eliminar este
                        indicador? 
                    </h4>
                </div>



                <div>
                    <a asp-controller="Indicators" asp-action="Index" class="btn btn-outline-success float-end">Cancelar</a>

                    <button type="submit" class="btn btn-outline-danger float-end">Aceptar</button>
                </div>
            </form>
        </div>
    </div>
</div>


