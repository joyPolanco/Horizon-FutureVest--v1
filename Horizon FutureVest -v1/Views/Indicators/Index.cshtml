@using Application.ViewModels.EconomicIndicator
@{
    ViewData["Title"] = "Mantenimiento de indicadores";
}

@model EconomicIndicatorFilterViewModel

<div class="container mt-4">
    <div class="row mb-3 d-flex">
        <div class="col-12 d-flex justify-content-end align-items-end">
            <a asp-action="Add" asp-controller="Indicators" class="btn btn-primary align-content-end">
                + Agregar Indicador
            </a>
        </div>
    </div>

    <div class="align-content-lg-around">
        <form asp-controller="Indicators" method="post" asp-action="Filter" class="p-3 rounded shadow-sm bg-white border">
            <div class="row align-items-end">
                <div class="col-auto">
                    <label class="form-label text-secondary">Año</label>
                    <select  class="form-select" asp-for="YearCurrentSelection">
                        <option value="">Todos</option>
                        @for(int i= DateTime.Now.Year-20; i<=DateTime.Now.Year+20; i++)
                        {
                            <option  >@i</option>
                        }
                    </select>
                </div>

                <div class="col-auto">
                    <label class="form-label">País</label>
                    <select class="form-select" asp-for="CountryIdCurrentSelection">
                        <option value="">Todos</option>
                        @foreach (var country in Model.Countries)
                        {
                            <option value="@country.Id">@country.Name</option>
                        }
                    </select>
                </div>


                <div class="col-auto">
                    <button class="btn btn-primary"  type="submit">Filtrar</button>
                </div>
            </div>
        </form>
    </div>
   
    </div>
<div id="indicatorsList">
    @await Html.PartialAsync("_EconomicIndicatorList", Model.EconomicIndicators)
</div>

